{
  "buildCommand": "pnpm run build && npx expo export --platform web --output public",
  "outputDirectory": "public",
  "installCommand": "pnpm install",
  "framework": "expo",
  "env": {
    "NODE_ENV": "production"
  },
  "functions": {
    "server/**/*.ts": {
      "runtime": "nodejs20.x"
    }
  }
}
